# Gemini / Upstash secrets (leave empty in source control)
GEMINI_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Application limits
GLOBAL_RPM_LIMIT=12
GLOBAL_RPD_LIMIT=400
GEMINI_RPM_LIMIT=15
GEMINI_RPD_LIMIT=500
USER_RPM_LIMIT=3
SESSION_REQUEST_LIMIT=15
REQUEST_LOCK_TTL_SECONDS=30
DUPLICATE_REQUEST_TTL_SECONDS=600
ANALYTICS_RETENTION_DAYS=14
GEMINI_REQUEST_TIMEOUT_MS=25000

# Use a long random secret. It is never sent to the browser.
ANONYMIZATION_SECRET=

# Administrator credentials / signed cookie
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_MAX_AGE_SECONDS=14400
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=600

# development | production (Vercel also sets VERCEL_ENV)
ENVIRONMENT=development
